# Copy this file to .env and fill in your values
# Get your API key at: https://itch.io/user/settings/api-keys
ITCH_API_KEY=your_api_key_here

# Optional: password-protect the dashboard frontend
# Leave blank for no password. Add the same variable as a GitHub secret
# for the GitHub Pages version.
DASHBOARD_PASSWORD=

# Optional: change the port (default: 3000)
# PORT=3000
